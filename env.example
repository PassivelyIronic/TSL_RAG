# =============================================================================
# TSL-RAG — Konfiguracja środowiska
# =============================================================================

APP_ENV=development
LOG_LEVEL=INFO

# Provider: "ollama" (lokalny, domyślny)
LLM_PROVIDER=ollama

# --- Ollama (lokalny, domyślny) ---
# Przed startem uruchom:
#   ollama pull mistral:7b-instruct-q4_K_M
#   ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=mistral:7b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_DIMENSIONS=768

# --- Gemini (Opcjonalne, wyłącznie pod ewaluację Ragas LLM-as-a-judge) ---
GEMINI_API_KEY=tu_wkleisz_swoj_klucz_kiedy_dojdziemy_do_testow

# --- PostgreSQL + pgvector ---
# Zgodne z Twoim docker-compose.yml
POSTGRES_DSN=postgresql+asyncpg://rag_user:rag_password@localhost:5432/tsl_vectordb

# --- Retrieval ---
RETRIEVAL_TOP_K=20
RETRIEVAL_RERANK_TOP_N=5
BM25_WEIGHT=0.3
DENSE_WEIGHT=0.7

# --- Reranker (CPU, ~90MB RAM, nie obciąża GPU) ---
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Generation ---
MAX_CONTEXT_TOKENS=4096
MAX_ANSWER_TOKENS=1024

# --- Ingestion ---
CHUNK_SIZE=400
CHUNK_OVERLAP=50
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
